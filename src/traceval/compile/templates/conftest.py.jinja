def pytest_addoption(parser):
    parser.addoption("--target", action="store", default=None, help="HTTP URL or module:fn")
    parser.addoption("--judge", action="store", default="fake", help="fake|openai")
    parser.addoption("--compare", action="store", default=None, help="Previous run JSON report")
    parser.addoption("--only", action="store", default=None, help="Filter by cluster or case ID")
    parser.addoption("--runs-dir", action="store", default=None, help="Directory for run reports (default: <evals>/runs)")

def pytest_configure(config):
    # Prevent pytest cache from polluting evals/
    config.option.cache_dir = str(Path(__file__).resolve().parent.parent / ".pytest_cache")

def pytest_generate_tests(metafunc):
    if "eval_case" in metafunc.fixturenames:
        # Load all cases recursively
        cases_dir = Path(__file__).parent / "cases"
        cases = []
        if cases_dir.exists():
            for p in cases_dir.rglob("*.yaml"):
                try:
                    with open(p, encoding="utf-8") as f:
                        data = yaml.safe_load(f)
                        if isinstance(data, dict) and "id" in data:
                            cases.append(data)
                except Exception:
                    pass

        # Sort cases by ID for deterministic execution
        cases.sort(key=lambda c: c["id"])

        # Filter by option --only
        only_opt = metafunc.config.getoption("--only")
        if only_opt:
            cases = [c for c in cases if only_opt in c["id"] or only_opt in c["cluster"]]

        metafunc.parametrize("eval_case", cases, ids=[c["id"] for c in cases])

